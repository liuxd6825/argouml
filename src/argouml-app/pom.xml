      <version>${project.version}</version>
      <scope>compile</scope>
    </dependency>

    <!-- Chinese localization bundle (vendor + patch merged inline).
         Vendored from https://github.com/argouml-tigris-org/argouml-i18n-zh
         (last upstream commit 89ec572, 2022-08-21). Activate at runtime with
         -Duser.language=zh -Duser.country=CN (Simplified) or
         -Duser.country=TW (Traditional). Compile scope so the bundle ships
         inside argouml-jar-with-dependencies.jar and shows up automatically in
         the IDEA run configuration's classpath.
         The 86 keys missing from upstream (34 from mnemonic + wfr bundles,
         plus 52 partial-additions) are appended directly to the vendor files
         in externals/argouml-i18n-zh/src/org/argouml/i18n/ as direct
         appends. A separate "patch" bundle was attempted but
         ResourceBundle.getBundle() does not merge across classpath;
         declaring both vendor and patch jars causes partial patch
         bundles to mask the complete vendor bundles. -->
    <dependency>
      <groupId>org.argouml</groupId>
      <artifactId>argouml-i18n-zh</artifactId>
      <version>${project.version}</version>
      <scope>compile</scope>
    </dependency>

