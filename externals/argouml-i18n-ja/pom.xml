<project xmlns="http://maven.org/POM/4.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.org/POM/4.0.0
                      http://maven.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.argouml</groupId>
    <artifactId>parentpom</artifactId>
    <version>0.35.5-SNAPSHOT</version>
  </parent>

  <artifactId>argouml-i18n-ja</artifactId>
  <version>0.35.2-SNAPSHOT</version>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>

  <name>argouml-ja</name>
  <description>
Japanese localization for ArgoUML.

This module is currently a SMOKE TEST ONLY — it ships only three keys to
verify the multi-language plumbing (iso-8859-1 .properties files, jar
shape, ResourceBundle fallback chain, locale selection via
-Duser.language=ja / -Duser.country=JP).

Translating the remaining ArgoUML strings into Japanese is welcome but
out of scope for this commit. See README.txt.
  </description>

  <build>
    <!-- No Java sources; just resources. Bundle layout must end up as
         org/argouml/i18n/*_ja_JP.properties inside the JAR so that
         org.argouml.i18n.Translator (which calls
         ResourceBundle.getBundle("org.argouml.i18n.<name>", locale)) can find
         them via the standard system classloader. -->
    <resources>
      <resource>
        <directory>src</directory>
        <targetPath>.</targetPath>
        <includes>
          <include>**/*.properties</include>
          <include>**/*.txt</include>
        </includes>
      </resource>
    </resources>
  </build>

  <scm>
    <url>https://github.com/argouml-tigris-org/argouml</url>
  </scm>
</project>
