<project xmlns="http://maven.org/POM/4.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.org/POM/4.0.0
                      http://maven.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.argouml</groupId>
    <artifactId>parentpom</artifactId>
    <version>0.35.5-SNAPSHOT</version>
  </parent>

  <!--
       Inherit artifactId / name / description from the zh module's pom.xml,
       then tailor to your language.

       artifactId  :  argouml-i18n-<lang-lowercase>   (e.g. argouml-i18n-fr)
       name        :  argouml-<lang>                   (e.g. argouml-fr)
       description :  human-readable summary
  -->
  <artifactId>argouml-i18n-<!--lang--></artifactId>
  <version>0.35.2-SNAPSHOT</version>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>

  <name>argouml-<!--lang--></name>
  <description>
[Language] localization for ArgoUML.
Bundled under externals/ following the i18n-template skeleton; see
../I18N_GUIDELINES.md and BUILD_INSTRUCTIONS.md.
Drop the produced JAR on ArgoUML's classpath and start with
-Duser.language=&lt;lang&gt; -Duser.country=&lt;COUNTRY&gt; to enable.
Missing keys fall back to English automatically.
  </description>

  <build>
    <!-- No Java sources; just resources. Bundle layout must end up as
         org/argouml/i18n/*_<lang>_*.properties inside the JAR so that
         org.argouml.i18n.Translator (which calls
         ResourceBundle.getBundle("org.argouml.i18n.<name>", locale)) can find
         them via the standard system classloader. -->
    <resources>
      <resource>
        <directory>src</directory>
        <targetPath>.</targetPath>
        <includes>
          <include>**/*.properties</include>
          <include>**/*.txt</include>
        </includes>
      </resource>
    </resources>
  </build>

  <scm>
    <url>https://github.com/argouml-tigris-org/argouml</url>
  </scm>
</project>
